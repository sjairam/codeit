#!/usr/bin/env bash
#
# Read hosts from a file and report whether CrowdStrike Falcon Sensor
# appears to be installed on each host via SSH.
#
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

HOSTS_FILE=""
SSH_USER=""
SSH_IDENTITY=""
CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"

declare -a SUMMARY_HOSTS SUMMARY_STATUS

print_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
print_warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_err()     { echo -e "${RED}[ERROR]${NC} $1"; }

usage() {
  cat << EOF
Usage: $(basename "$0") -f HOSTS_FILE [OPTIONS]

  -f, --file FILE     Path to hosts file (one host per line; # comments; first column is used)
  -u, --user USER     SSH user (optional; else use ssh default / config)
  -i, --identity FILE SSH private key file
  -h, --help          Show this help

Environment:
  CONNECT_TIMEOUT   Seconds for SSH connect timeout (default: 10)

Each line can be: hostname, user@hostname, or hostname with extra fields (only the first field is used).
EOF
}

ssh_cmd() {
  local -a args=(
    -o BatchMode=yes
    -o ConnectTimeout="$CONNECT_TIMEOUT"
    -o StrictHostKeyChecking=accept-new
  )
  if [[ -n "$SSH_IDENTITY" ]]; then
    args+=(-i "$SSH_IDENTITY")
  fi
  ssh "${args[@]}" "$@"
}

run_remote_crowdstrike_check() {
  local target=$1
  local out ec=0 status="UNKNOWN"

  out=$(
    ssh_cmd "$target" "bash -s" << 'REMOTE'
set -euo pipefail

installed=0
details=""

if systemctl list-unit-files 2>/dev/null | grep -q '^falcon-sensor\.service'; then
  installed=1
  details="systemd service: falcon-sensor.service"
elif command -v dpkg-query >/dev/null 2>&1 && dpkg-query -W -f='${Status}\n' falcon-sensor 2>/dev/null | grep -q 'install ok installed'; then
  installed=1
  details="dpkg package: falcon-sensor"
elif command -v rpm >/dev/null 2>&1 && rpm -q falcon-sensor >/dev/null 2>&1; then
  installed=1
  details="rpm package: falcon-sensor"
elif [[ -x /opt/CrowdStrike/falconctl ]]; then
  installed=1
  details="binary present: /opt/CrowdStrike/falconctl"
fi

if [[ "$installed" -eq 1 ]]; then
  echo "__CROWDSTRIKE_STATUS__:INSTALLED:${details}"
else
  echo "__CROWDSTRIKE_STATUS__:NOT_INSTALLED:"
fi
REMOTE
  ) || ec=$?

  status_line="$(printf '%s\n' "$out" | sed -n 's/^__CROWDSTRIKE_STATUS__://p' | tail -n1)"
  if [[ -n "$status_line" ]]; then
    status="${status_line%%:*}"
    details="${status_line#*:}"
  else
    details=""
  fi

  case "$status" in
    INSTALLED)
      echo -e "${GREEN}CrowdStrike:${NC} INSTALLED ${details:+($details)}"
      SUMMARY_HOSTS+=("$target")
      SUMMARY_STATUS+=("INSTALLED")
      ;;
    NOT_INSTALLED)
      echo -e "${YELLOW}CrowdStrike:${NC} NOT_INSTALLED"
      SUMMARY_HOSTS+=("$target")
      SUMMARY_STATUS+=("NOT_INSTALLED")
      ;;
    *)
      if [[ "$ec" -ne 0 ]]; then
        print_err "SSH or remote command failed for $target"
      else
        print_warn "Could not determine CrowdStrike status for $target"
      fi
      SUMMARY_HOSTS+=("$target")
      SUMMARY_STATUS+=("ERROR")
      ;;
  esac

  return "$ec"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--file)
      HOSTS_FILE="${2:-}"
      shift 2
      ;;
    -u|--user)
      SSH_USER="${2:-}"
      shift 2
      ;;
    -i|--identity)
      SSH_IDENTITY="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      print_err "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ -z "$HOSTS_FILE" ]]; then
  print_err "Hosts file is required (-f/--file)."
  usage
  exit 1
fi

if [[ ! -f "$HOSTS_FILE" ]]; then
  print_err "Hosts file not found: $HOSTS_FILE"
  exit 1
fi

print_info "Hosts file: $HOSTS_FILE"
[[ -n "$SSH_USER" ]] && print_info "SSH user: $SSH_USER"
echo

failures=0
while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  [[ -z "$line" ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  if [[ "$line" == *"#"* ]]; then
    line="${line%%#*}"
    line="${line%"${line##*[![:space:]]}"}"
  fi
  [[ -z "$line" ]] && continue

  read -r first _ <<< "$line"
  host="$first"
  [[ -z "$host" ]] && continue

  target="$host"
  if [[ -n "$SSH_USER" ]] && [[ "$host" != *"@"* ]]; then
    target="${SSH_USER}@${host}"
  fi

  echo "========================================"
  echo -e "${GREEN}Host:${NC} $target"
  echo "========================================"

  if ! run_remote_crowdstrike_check "$target"; then
    ((failures++)) || true
  fi
  echo
done < "$HOSTS_FILE"

echo "========================================"
echo -e "${GREEN}Summary: CrowdStrike installation${NC}"
echo "========================================"
printf "%-50s %16s\n" "HOST" "STATUS"
i=0
while [[ $i -lt ${#SUMMARY_HOSTS[@]} ]]; do
  printf "%-50s %16s\n" "${SUMMARY_HOSTS[i]}" "${SUMMARY_STATUS[i]}"
  ((i++)) || true
done
echo

if [[ "$failures" -gt 0 ]]; then
  print_warn "Completed with $failures host(s) reporting errors."
  exit 1
fi
print_info "Done."
exit 0

#!/usr/bin/env bash
#
# Read hosts from a file and report disk usage for /github-actions-runner/ on each host via SSH.
#
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

RUNNER_PATH="/github-runners-work"
HOSTS_FILE=""
SSH_USER=""
SSH_IDENTITY=""
CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-10}"

declare -a SUMMARY_HOSTS SUMMARY_KB

print_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
print_warn()    { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_err()     { echo -e "${RED}[ERROR]${NC} $1"; }

usage() {
  cat << EOF
Usage: $(basename "$0") -f HOSTS_FILE [OPTIONS]

  -f, --file FILE     Path to hosts file (one host per line; # comments; first column is used)
  -u, --user USER     SSH user (optional; else use ssh default / config)
  -p, --path PATH     Directory to check (default: $RUNNER_PATH)
  -i, --identity FILE SSH private key file
  -h, --help          Show this help

Environment:
  CONNECT_TIMEOUT   Seconds for SSH connect timeout (default: 10)

Each line can be: hostname, user@hostname, or hostname with extra fields (only the first field is used).

Example hosts file:
  # runners
  runner01.internal
  ubuntu@runner02.internal

Remote checks:
  - df -hP on the path (filesystem free space for that mount)
  - du -sh on the path (space used by the directory)
  - A summary table at the end lists space used on each host
EOF
}

# du -sk reports 1024-byte blocks; format for display
human_from_kb() {
  local kb=$1
  if [[ -z "$kb" || "$kb" == "-" ]]; then
    echo "N/A"
    return
  fi
  if command -v numfmt >/dev/null 2>&1; then
    numfmt --to=iec-i --suffix=B --from-unit=1024 "$kb" 2>/dev/null && return
  fi
  local b=$((kb * 1024))
  awk -v b="$b" 'BEGIN{
    split("B KB MB GB TB PB", u, " ");
    i=1; while (b>=1024 && i<6) { b/=1024; i++ }
    printf "%.2f %s\n", b, u[i]
  }'
}

ssh_cmd() {
  local -a args=(
    -o BatchMode=yes
    -o ConnectTimeout="$CONNECT_TIMEOUT"
    -o StrictHostKeyChecking=accept-new
  )
  if [[ -n "$SSH_IDENTITY" ]]; then
    args+=(-i "$SSH_IDENTITY")
  fi
  ssh "${args[@]}" "$@"
}

run_remote_disk_check() {
  local target=$1
  local out kb ec=0
  # Capture stdout even when ssh exits non-zero, so df/du output is never dropped.
  out=$(
    ssh_cmd "$target" "RUNNER_PATH=$(printf '%q' "$RUNNER_PATH") bash -s" << 'REMOTE'
set -euo pipefail
echo "--- df (filesystem containing path) ---"
if df -hP "$RUNNER_PATH" 2>/dev/null; then
  :
else
  echo "(df failed - path may be missing)"
  df -hP / 2>/dev/null || true
fi
echo
echo "--- du (directory size) ---"
if du -sh "$RUNNER_PATH" 2>/dev/null; then
  :
else
  echo "(du failed - path may not exist)"
fi
usage_kb=""
if usage_kb=$(du -sk "$RUNNER_PATH" 2>/dev/null | awk '{print $1; exit}'); then
  :
else
  usage_kb=""
fi
echo "__RUNNER_USAGE_KB__:${usage_kb:-}"
REMOTE
  ) || ec=$?
  kb=$(printf '%s\n' "$out" | sed -n 's/^__RUNNER_USAGE_KB__:\(.*\)$/\1/p' | tail -n1)
  SUMMARY_HOSTS+=("$target")
  SUMMARY_KB+=("${kb:-}")
  echo -e "${BLUE}Space used on ${RUNNER_PATH}:${NC} $(human_from_kb "${kb:-}")"
  echo
  printf '%s\n' "$out" | sed '/^__RUNNER_USAGE_KB__:/d'
  return "$ec"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--file)
      HOSTS_FILE="${2:-}"
      shift 2
      ;;
    -u|--user)
      SSH_USER="${2:-}"
      shift 2
      ;;
    -p|--path)
      RUNNER_PATH="${2:-}"
      shift 2
      ;;
    -i|--identity)
      SSH_IDENTITY="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      print_err "Unknown option: $1"
      usage
      exit 1
      ;;
  esac
done

if [[ -z "$HOSTS_FILE" ]]; then
  print_err "Hosts file is required (-f/--file)."
  usage
  exit 1
fi

if [[ ! -f "$HOSTS_FILE" ]]; then
  print_err "Hosts file not found: $HOSTS_FILE"
  exit 1
fi

print_info "Runner path: $RUNNER_PATH"
print_info "Hosts file: $HOSTS_FILE"
[[ -n "$SSH_USER" ]] && print_info "SSH user: $SSH_USER"
echo

failures=0
while IFS= read -r line || [[ -n "$line" ]]; do
  # Trim leading/trailing whitespace
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  [[ -z "$line" ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  # Drop inline comments (unquoted # starts comment)
  if [[ "$line" == *"#"* ]]; then
    line="${line%%#*}"
    line="${line%"${line##*[![:space:]]}"}"
  fi
  [[ -z "$line" ]] && continue

  read -r first _ <<< "$line"
  host="$first"
  [[ -z "$host" ]] && continue

  target="$host"
  if [[ -n "$SSH_USER" ]] && [[ "$host" != *"@"* ]]; then
    target="${SSH_USER}@${host}"
  fi

  echo "========================================"
  echo -e "${GREEN}Host:${NC} $target"
  echo "========================================"
  if ! run_remote_disk_check "$target"; then
    print_err "SSH or remote command failed for $target"
    SUMMARY_HOSTS+=("$target")
    SUMMARY_KB+=("-")
    ((failures++)) || true
  fi
  echo
done < "$HOSTS_FILE"

echo "========================================"
echo -e "${GREEN}Summary: space used at ${RUNNER_PATH}${NC}"
echo "========================================"
printf "%-50s %16s\n" "HOST" "SPACE USED"
i=0
while [[ $i -lt ${#SUMMARY_HOSTS[@]} ]]; do
  printf "%-50s %16s\n" "${SUMMARY_HOSTS[i]}" "$(human_from_kb "${SUMMARY_KB[i]}")"
  ((i++)) || true
done
echo

if [[ "$failures" -gt 0 ]]; then
  print_warn "Completed with $failures host(s) reporting errors."
  exit 1
fi
print_info "Done."
exit 0
